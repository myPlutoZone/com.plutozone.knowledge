defaults
auth			on
tls			on
tls_trust_file		/etc/ssl/certs/ca-bundle.crt		# for Redhat
# tls_trust_file	/etc/ssl/certs/ca-certificates.crt	# for Ubuntu
logfile			~/msmtp.log

# ---------------------------------------------------------
# 1. Required Enable 2 Step Verification on Google Account
# ---------------------------------------------------------
account gmail
host smtp.gmail.com
port 587

# ---------------------------------------------------------
# 2-1. Sender's Email(ex: smtp@plutozone.com or contact@plutozone.com)
# ---------------------------------------------------------
from [EMAIL]

# ---------------------------------------------------------
# 2-2. Login User Email for SMTP(ex: smtp@plutozone.com)
# ---------------------------------------------------------
user [EMAIL]

# ---------------------------------------------------------
# 3. Required Generate App Password at Login User Email
# ---------------------------------------------------------
password [APPPASSWORD]

account default : gmail